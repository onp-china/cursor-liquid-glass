{
    "workbench.colorTheme": "Material Theme Palenight",
    "workbench.iconTheme": "eq-material-theme-icons",
    "editor.semanticHighlighting.enabled": true,
    "window.titleBarStyle": "custom",
    "window.systemColorTheme": "dark",
    "window.autoDetectColorScheme": false,

    "vscode_vibrancy.type": "fullscreen-ui",
    "vscode_vibrancy.opacity": 0.25,
    "vscode_vibrancy.refreshInterval": 100,
    "vscode_vibrancy.disableFramelessWindow": false,
    "vscode_vibrancy.disableThemeFixes": false,
    "vscode_vibrancy.disableColorCustomizations": true,
    "vscode_vibrancy.imports": [
        "/Users/REPLACE_ME/Library/Application Support/Cursor/User/liquid-glass-chat-fix.css"
    ],

